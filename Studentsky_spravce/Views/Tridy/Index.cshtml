@model List<Studentsky_spravce.Models.Trida>

@{
    ViewData["Title"] = "Tridy";
}

<div class="container mt-4">
    <h1 class="mb-4">Seznam Trid</h1>

    <a class="btn btn-primary mb-3" asp-action="Create">
        Přidat Tridu
    </a>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nazev</th>
                <th>Tridni Ucitel</th>
                <th>Studente</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var Trida in Model)
            {
                <tr>
                    <td>@Trida.Nazev</td>
                    <td>@Trida.TridniUcitel?.Jmeno @Trida.TridniUcitel?.Prijmeni</td>
                    <td>
                    @foreach (var student in Trida.Studente)
                    {
                        <div>
                            @student.Jmeno @student.Prijmeni
                        </div>
                    }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@Trida.Id" class="btn btn-warning">
                            Upravit
                        </a>

                        @if (Trida.Rozvrh != null && Trida.Rozvrh.Id != 0)
                        {
                            <a asp-controller="Rozvrh" asp-action="Index" asp-route-id="@Trida.Rozvrh.Id" class="btn btn-warning">
                                Zobrazit
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">Rozvrh neexistuje</span>
                        }
                        <form asp-action="Delete" asp-route-id="@Trida.Id" method="post" style="display:inline;"
                              onsubmit="return confirm('Opravdu chceš smazat tuto třídu?');">
                            <button type="submit" class="btn btn-danger">
                                Smazat
                            </button>
                        </form>
                    </td>
                   
                </tr>
            }
        </tbody>
    </table>
</div>