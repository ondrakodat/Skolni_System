@model List<Studentsky_spravce.Models.Trida>

@{
    ViewData["Title"] = "Tridy";
}

<div class="container mt-4">
    <h1 class="mb-4">Seznam Trid</h1>

    <a class="btn btn-primary mb-3" asp-action="Create">
        Přidat Tridu
    </a>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nazev</th>
                <th>Tridni Ucitel</th>
                <th>Studente</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var Trida in Model)
            {
                <tr>
                    <td>@Trida.Nazev</td>
                    <td>@Trida.TridniUcitel?.Jmeno @Trida.TridniUcitel.Prijmeni</td>
                    <td>
                    @foreach (var student in Trida.Studente)
                    {
                        <div>
                            @student.Jmeno @student.Prijmeni
                        </div>
                    }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>