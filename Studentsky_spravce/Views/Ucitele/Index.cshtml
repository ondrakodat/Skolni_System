@model List<Studentsky_spravce.Models.Ucitel>

@{
    ViewData["Title"] = "Učitelé";
}

<div class="container mt-4">
    <h1 class="mb-4">Seznam učitelů</h1>

    <a class="btn btn-primary mb-3" asp-action="Create">
        Přidat učitele
    </a>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Jméno</th>
                <th>Příjmení</th>
                <th>Věk</th>
                <th>Email</th>
                <th>Akce</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var ucitel in Model)
            {
                <tr>
                    <td>@ucitel.Jmeno</td>
                    <td>@ucitel.Prijmeni</td>
                    <td>@ucitel.Vek</td>
                    <td>@ucitel.Email</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@ucitel.Id" class="btn btn-warning">
                            Upravit
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>