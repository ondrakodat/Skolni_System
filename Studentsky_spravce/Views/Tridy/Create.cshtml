@model Studentsky_spravce.Models.Trida

@{
    ViewData["Title"] = "Přidat třídu";

    var studenti = ViewBag.Studenti as List<Studentsky_spravce.Models.Student>;
    var ucitele = ViewBag.Ucitele as List<Studentsky_spravce.Models.Ucitel>;
}

<div class="container mt-4">
    <h1>Přidat třídu</h1>

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label asp-for="Nazev" class="form-label">Název třídy</label>
            <input asp-for="Nazev" class="form-control" placeholder="Např. IT1" />
            <span asp-validation-for="Nazev" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Třídní učitel</label>

            <select name="tridniUcitel" class="form-control">
                <option value="">-- Vyber učitele --</option>

                @if (ucitele != null)
                {
                    foreach (var ucitel in ucitele)
                    {
                        <option value="@ucitel.Id">
                            @ucitel.Jmeno @ucitel.Prijmeni
                        </option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Studenti ve třídě</label>

            @if (studenti != null && studenti.Any())
            {
                foreach (var student in studenti)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="vybraniStudenti"
                               value="@student.Id"
                               id="student_@student.Id" />

                        <label class="form-check-label" for="student_@student.Id">
                            @student.Jmeno @student.Prijmeni
                        </label>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Zatím nejsou v databázi žádní studenti.</p>
            }
        </div>

        <button type="submit" class="btn btn-primary">Uložit třídu</button>
        <a asp-action="Index" class="btn btn-secondary">Zpět na seznam</a>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}