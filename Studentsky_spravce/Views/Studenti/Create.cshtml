@model Studentsky_spravce.Models.Student

@{
    ViewData["Title"] = "Přidat studenta";
}

<div class="container mt-4">
    <h1>Přidat studenta</h1>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Jmeno" class="form-label">Jméno</label>
            <input asp-for="Jmeno" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Prijmeni" class="form-label">Příjmení</label>
            <input asp-for="Prijmeni" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Vek" class="form-label">Věk</label>
            <input asp-for="Vek" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Uložit</button>
        <a asp-action="Index" class="btn btn-secondary">Zpět na seznam</a>
    </form>
</div>